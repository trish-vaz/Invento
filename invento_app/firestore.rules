rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsUserData(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, write: if ownsUserData(userId);

      match /{document=**} {
        allow read, write: if ownsUserData(userId);
      }
    }
  }
}
